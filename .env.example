# Optional. Defaults to ~/.dingtalk-radar
DINGTALK_RADAR_DATA_DIR=

# Comma-separated names / userIds used to detect messages that mention you.
# DingTalk @-mentions use userIds (`@<userId>`); display names from `dws contact me` also work.
# Example: DINGTALK_RADAR_MY_NAMES=张三,zhangsan,ding_userid_123
DINGTALK_RADAR_MY_NAMES=

# Use demo data when the `dws` CLI is unavailable. Set to 1 to enable.
DINGTALK_RADAR_DEMO=0

# Optional path / name for the dws executable (default: dws on PATH).
DINGTALK_RADAR_DWS_BIN=

# Comma-separated openConversationId list — groups to track when not
# selected interactively. Each id is fetched via `dws chat message list --group`.
DINGTALK_RADAR_GROUPS=

# Optional model name used by Codex CLI based topic/link summarization.
DINGTALK_RADAR_CODEX_MODEL=

# Optional. Tune Codex CLI aggregation.
DINGTALK_RADAR_TOPIC_CHUNK_SIZE=250
DINGTALK_RADAR_CODEX_TIMEOUT_MS=300000
DINGTALK_RADAR_LINK_CODEX_TIMEOUT_MS=180000
DINGTALK_RADAR_AUTO_TOPIC_DAYS=31
